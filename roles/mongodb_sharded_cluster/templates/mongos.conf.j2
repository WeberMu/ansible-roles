systemLog:
  destination: file
  path: {{ mongodb_log_root }}/mongos.log
  logAppend: true
processManagement:
  fork: true
net:
  bindIp: {{ mongodb_bind_ip }}
  port: {{ mongodb_port_mongos }}
security:
  keyFile: {{ mongodb_keyfile_path }}
sharding:
  configDB: {{ mongodb_config_replset }}/{{ groups[mongodb_config_servers_group] | map('regex_replace', '$', ':' ~ mongodb_port_mongod|string) | join(',') }}
